      "updated": 1717000000000,
      "link": null,
      "locked": false,
      "text": "@notionhq/client + REST Markdown API\nRate limited: p-queue (1 req/334ms)\nAuto-retry: p-retry (3 attempts)\n\nPublisher agent calls tools via Mastra\nWorkflow publish calls direct fns\nBoth paths share the rate limiter",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "@notionhq/client + REST Markdown API\nRate limited: p-queue (1 req/334ms)\nAuto-retry: p-retry (3 attempts)\n\nPublisher agent calls tools via Mastra\nWorkflow publish calls direct fns\nBoth paths share the rate limiter",
      "lineHeight": 1.25,
      "autoResize": true
    },
