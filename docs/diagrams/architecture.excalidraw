    {
      "id": "text_37",
      "type": "text",
      "x": 346,
      "y": 628,
      "width": 541,
      "height": 46,
      "angle": 0,
      "strokeColor": "#ced4da",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 4884201,
      "version": 1,
      "versionNonce": 4949738,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1717000000000,
      "link": null,
      "locked": false,
      "text": "GOOGLE_API_KEYS = key1, key2, key3      (comma-separated, validated by Zod)\nRound-robin:  Harvest → key1  |  Narrator → key2  |  Publisher → key3\n500 RPD per key × 3 = 1,500 effective RPD — weekly runs + dev testing comfortably",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GOOGLE_API_KEYS = key1, key2, key3      (comma-separated, validated by Zod)\nRound-robin:  Harvest → key1  |  Narrator → key2  |  Publisher → key3\n500 RPD per key × 3 = 1,500 effective RPD — weekly runs + dev testing comfortably",
      "lineHeight": 1.25,
      "autoResize": true
    },
