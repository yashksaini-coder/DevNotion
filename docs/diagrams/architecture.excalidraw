      "updated": 1717000000000,
      "link": null,
      "locked": false,
      "text": "NOTION_TOKEN\nNotion-Version: 2026-03-11\n\nEndpoints:\n  POST  /v1/search\n  POST  /v1/pages\n  PATCH /v1/pages/:id\n  PATCH /v1/pages/:id\n        /markdown\n\nRate limited:\n  p-queue + p-retry\n  ~3 req/sec",
      "fontSize": 11.5,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "NOTION_TOKEN\nNotion-Version: 2026-03-11\n\nEndpoints:\n  POST  /v1/search\n  POST  /v1/pages\n  PATCH /v1/pages/:id\n  PATCH /v1/pages/:id\n        /markdown\n\nRate limited:\n  p-queue + p-retry\n  ~3 req/sec",
      "lineHeight": 1.25,
      "autoResize": true
    },
