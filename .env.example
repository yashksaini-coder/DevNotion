# .env.example — copy to .env.local, fill in values

# GitHub — Personal Access Token (read:user, repo scope)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your_github_username

# Google AI Studio — comma-separated keys for rate limit rotation
# Get free keys at aistudio.google.com (create multiple under different projects)
GOOGLE_API_KEYS=AIzaSy_key1,AIzaSy_key2,AIzaSy_key3

# Notion — Internal Integration Token (read + write content)
NOTION_TOKEN=ntn_your_token_here
NOTION_PARENT_PAGE_ID=your_notion_page_uuid_or_url

# Optional: override default models
# NARRATOR_MODEL=gemini-3-pro-preview        # Best writing quality (25 RPD/key)
# UTILITY_MODEL=gemini-3-flash-preview       # Fast utility work (500 RPD/key)

# Optional: override default behavior
# BLOG_TONE=professional                     # professional | casual | technical | storytelling
# AUTO_PUBLISH=true
# LOG_LEVEL=info
