# .env.example — copy to .env.local, fill in values

# GitHub — Personal Access Token (read:user, repo scope)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_USERNAME=your_github_username

# Groq — free at console.groq.com
GROQ_API_KEY=gsk_your_key_here

# Notion — Internal Integration Token (read + write content)
NOTION_TOKEN=ntn_your_token_here
NOTION_PARENT_PAGE_ID=your_notion_page_uuid

# Excalidraw MCP canvas — started via docker-compose
EXCALIDRAW_CANVAS_URL=http://localhost:3000

# Optional: override default behavior
BLOG_TONE=professional
AUTO_PUBLISH=true
DIAGRAM_STYLE=sketch
LOG_LEVEL=info
